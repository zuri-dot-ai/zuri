# ════════════════════════════════════════════════════════
#  ZURI — Environment Variables
#  Copy this file to PROJECT ROOT as .env.local and fill in.
#  NEVER commit .env.local to Git.
#  Do NOT put .env.local under src/app/ — Next.js loads from root.
# ════════════════════════════════════════════════════════

# ── APP ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Apex marketing site (static deploy) — Home, Pricing, About, Privacy, Terms
NEXT_PUBLIC_MARKETING_URL=https://buildzuri.com
# Production root domain for subdomain routing (docs/02_WEBSITE_BUILDER.md §15)
NEXT_PUBLIC_ROOT_DOMAIN=buildzuri.com
# How live site URLs are formed: path (interim Vercel) | subdomain (after wildcard DNS)
NEXT_PUBLIC_SITE_URL_MODE=path
# Local dev override: NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# ── SUPABASE ────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PROJECT_ID=your_project_ref_id

# ── GEMINI (Google AI Studio — default) ─────────────────
# From: https://aistudio.google.com/app/apikey (keys usually start with AIza)
# Required unless GEMINI_USE_VERTEX=true
# Keep GEMINI_USE_VERTEX unset or false for AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_USE_VERTEX=false
# Model names (override if needed)
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
# Optional Vertex AI backend (needs aiplatform.googleapis.com enabled)
# GEMINI_USE_VERTEX=true
# GOOGLE_APPLICATION_CREDENTIALS=./zuri-service-account.json
# GEMINI_PROJECT_ID=your-gcp-project-id
# GEMINI_LOCATION=us-central1

# ── FLUTTERWAVE ─────────────────────────────────────────
# From: Flutterwave Dashboard → Settings → API
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxx
FLW_SECRET_KEY=FLWSECK_TEST-xxxxx
FLW_ENCRYPTION_KEY=xxxxx
FLW_SECRET_HASH=your_webhook_secret_hash
# Plan IDs — canonical: free | pro | growth | premium
FLW_PLAN_PRO_MONTHLY=
FLW_PLAN_GROWTH_MONTHLY=
FLW_PLAN_PREMIUM_MONTHLY=
FLW_PLAN_PRO_ANNUAL=
FLW_PLAN_GROWTH_ANNUAL=
FLW_PLAN_PREMIUM_ANNUAL=

# ── RESEND (Platform Emails) ────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Zuri <hello@buildzuri.com>
# Website/contact emails: "log" (default, console only) | "send" (Resend).
# Keep "log" until real inbox delivery is explicitly approved.
EMAIL_DELIVERY_MODE=log

# ── WEBSITE BUILDER (docs/02_WEBSITE_BUILDER.md §15) ─────
# Images come from category_images (Supabase Storage), not Unsplash/Pexels.
# Secret for internal generate-website / cron callers
INTERNAL_API_SECRET=your_internal_api_secret_here

# ── SECURITY ────────────────────────────────────────────
# Used to encrypt OAuth tokens (platform_connections table)
# Generate: openssl rand -base64 32
ENCRYPTION_SECRET=your_32_byte_base64_secret