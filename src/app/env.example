# ════════════════════════════════════════════════════════
#  ZURI — Environment Variables
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local to Git.
# ════════════════════════════════════════════════════════

# ── APP ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# In production: NEXT_PUBLIC_ROOT_DOMAIN=zuri.app

# ── SUPABASE ────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_PROJECT_ID=your_project_ref_id

# ── GEMINI (Google AI Studio) ───────────────────────────
# From: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model names (override if needed)
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# ── FLUTTERWAVE ─────────────────────────────────────────
# From: Flutterwave Dashboard → Settings → API
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxx
FLW_SECRET_KEY=FLWSECK_TEST-xxxxx
FLW_ENCRYPTION_KEY=xxxxx
FLW_SECRET_HASH=your_webhook_secret_hash
# Plan IDs (created via /api/flutterwave/create-plan or dashboard)
FLW_PLAN_STARTER_MONTHLY=
FLW_PLAN_GROWTH_MONTHLY=
FLW_PLAN_STARTER_ANNUAL=
FLW_PLAN_GROWTH_ANNUAL=

# ── RESEND (Platform Emails) ────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=Zuri <hello@zuri.app>

# ── UNSPLASH (Stock Photos) ─────────────────────────────
# From: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── PEXELS (Stock Video) ────────────────────────────────
# From: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# ── SECURITY ────────────────────────────────────────────
# Used to encrypt OAuth tokens (platform_connections table)
# Generate: openssl rand -base64 32
ENCRYPTION_SECRET=your_32_byte_base64_secret